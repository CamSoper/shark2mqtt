# Shark account credentials (required)
SHARK_USERNAME=your@email.com
SHARK_PASSWORD=your_password

# Region: "us" or "eu" (default: us)
# SHARK_REGION=us

# SharkNinja household ID (required)
# Found in the skegox API URLs: /devicesEndUserController/{HOUSEHOLD_ID}/...
SHARK_HOUSEHOLD_ID=

# MQTT broker (required)
MQTT_HOST=localhost
# MQTT_PORT=1883
# MQTT_USERNAME=
# MQTT_PASSWORD=

# MQTT topic prefix (default: shark2mqtt)
# MQTT_PREFIX=shark2mqtt

# Polling interval in seconds (default: 300 = 5 min)
# POLL_INTERVAL=300

# Active polling interval when a vacuum is cleaning (default: 20)
# Matches the vacuum's own undocked report rate
# POLL_INTERVAL_ACTIVE=20

# Directory to persist auth tokens (default: /data)
# TOKEN_DIR=/data

# Logging level: DEBUG, INFO, WARNING, ERROR (default: INFO)
# LOG_LEVEL=INFO
